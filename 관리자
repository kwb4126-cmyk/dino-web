<!DOCTYPE html>
<html>
<body style="background:#111; color:#fff; padding:20px;">
    <div id="authArea">
        <h2>관리자 로그인</h2>
        <input type="password" id="pw" placeholder="비밀번호 입력">
        <button onclick="login()">접속</button>
    </div>
    <div id="dashboard" style="display:none;">
        <h2>주문 관리</h2>
        <div id="orderList"></div>
    </div>

    <script>
        function login() {
            // 여기에 원하는 관리자 비밀번호를 설정하세요
            if (document.getElementById('pw').value === "admin1234") {
                document.getElementById('authArea').style.display = 'none';
                document.getElementById('dashboard').style.display = 'block';
                // loadData(); // 여기에 데이터를 불러오는 함수 호출
            } else {
                alert("비밀번호가 틀렸습니다.");
            }
        }
    </script>
</body>
</html>
